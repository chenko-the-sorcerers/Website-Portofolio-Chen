{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/pages/ai-lab/(.*)", "destination": "/pages/ai-lab/$1.html" },
    { "source": "/pages/(.*)", "destination": "/pages/$1.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [{ "key": "X-Content-Type-Options", "value": "nosniff" }]
    }
  ]
}
